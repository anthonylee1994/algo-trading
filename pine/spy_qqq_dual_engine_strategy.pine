//@version=6
strategy("SPY/QQQ 雙引擎: 順勢突破 + RSI2 撈底",
     overlay = true,
     pyramiding = 0,
     initial_capital = 100000,
     default_qty_type = strategy.percent_of_equity,
     default_qty_value = 100, // 實盤建議調低, 例如 20-30%
     commission_type = strategy.commission.percent,
     commission_value = 0.02, // 2bps 單邊, 貼近 IBKR 現實
     slippage = 1,
     process_orders_on_close = true) // 收市確認訊號即刻執行, 同回測研究一致

// ============================================================
// 2026-07-03 回測驗證 (yfinance 日線, auto-adjust, 連 2bps 成本):
//
//   QQQ 1999-2026: Sharpe 0.72 / CAGR 11.1% / MaxDD -42.6%  (BH: 0.52 / -83%)
//   QQQ 2009-2026: Sharpe 1.11 / CAGR 16.2% / MaxDD -21.1%  (BH: 1.01 / -35%)
//   SPY 1999-2026: Sharpe 0.69 / CAGR  7.7% / MaxDD -31.5%  (BH: 0.53 / -55%)
//   SPY 2009-2026: Sharpe 0.96 / CAGR 11.8% / MaxDD -17.5%  (BH: 0.87 / -34%)
//
//   設計原理: 兩個互補引擎, 同一時間只持一個倉
//   1) 突破主倉: 15日新高 + 淨MACD(5,35)>0 先入場, 跌穿20日新低出場
//      —— 只追有動能確認嘅強勢, 熊市自動離場 (所以 DD 細一半)
//   2) RSI2 撈底: 空倉時 RSI(2)<10 且企喺 200MA 之上就接, RSI(2)>70 走
//      —— 趨勢策略最怕震盪市, 震盪市正正係均值回歸嘅糧倉
//   注意: 突破引擎加 200MA 濾網已驗證係有害 (錯過V型反彈), 唔好加
// ============================================================

// --- 輸入參數: 突破引擎 ---
breakoutLen = input.int(15, "新高日數 (突破)", minval = 1, group = "突破引擎")
exitLen     = input.int(20, "新低日數 (出場)", minval = 1, group = "突破引擎")
fastLen     = input.int(5,  "MACD 快線", minval = 1, group = "突破引擎")
slowLen     = input.int(35, "MACD 慢線", minval = 1, group = "突破引擎")

// --- 輸入參數: RSI2 撈底引擎 ---
useMr       = input.bool(true, "啟用 RSI2 撈底", group = "RSI2 撈底引擎")
rsiLen      = input.int(2,  "RSI 長度", minval = 1, group = "RSI2 撈底引擎")
mrBuyTh     = input.int(10, "RSI 買入門檻 (<)", minval = 1, maxval = 50, group = "RSI2 撈底引擎")
mrSellTh    = input.int(70, "RSI 賣出門檻 (>)", minval = 50, maxval = 99, group = "RSI2 撈底引擎")
maLen       = input.int(200, "趨勢 MA (撈底只喺 MA 之上)", minval = 1, group = "RSI2 撈底引擎")

// --- 指標計算 ---
macdLine    = ta.ema(close, fastLen) - ta.ema(close, slowLen) // 淨 MACD, 唔使訊號線
highestHigh = ta.highest(high, breakoutLen)[1] // 前一根 K 線為止嘅極值, 避免自己計入
lowestLow   = ta.lowest(low, exitLen)[1]
ma          = ta.sma(close, maLen)
rsiVal      = ta.rsi(close, rsiLen)

// --- 訊號判斷 ---
boEntry = high > highestHigh and macdLine > 0            // 突破入場
boExit  = low < lowestLow                                 // 突破出場
mrEntry = useMr and rsiVal < mrBuyTh and close > ma       // 撈底入場
mrExit  = rsiVal > mrSellTh                               // 撈底出場

// --- 交易執行: 突破優先, 同一時間只持一個倉 ---
var string mode = ""

if strategy.position_size <= 0
    if boEntry
        strategy.entry("突破", strategy.long)
        mode := "BO"
    else if mrEntry
        strategy.entry("撈底", strategy.long)
        mode := "MR"
else
    if mode == "BO" and boExit
        strategy.close("突破")
    else if mode == "MR" and mrExit
        strategy.close("撈底")

// --- 繪圖可視化 ---
plot(highestHigh, "新高線 (突破)", color = color.new(color.green, 60), linewidth = 1)
plot(lowestLow, "新低線 (出場)", color = color.new(color.red, 60), linewidth = 1)
plot(ma, "趨勢 MA", color = color.new(color.blue, 50), linewidth = 2)

bgcolor(strategy.position_size > 0 ? (mode == "BO" ? color.new(color.green, 92) : color.new(color.aqua, 92)) : na)

plotshape(strategy.position_size <= 0 and boEntry, "突破入場", shape.triangleup, location.belowbar, color = color.green, size = size.small)
plotshape(strategy.position_size <= 0 and not boEntry and mrEntry, "撈底入場", shape.triangleup, location.belowbar, color = color.aqua, size = size.small)
plotshape(strategy.position_size > 0 and mode == "BO" and boExit, "突破出場", shape.triangledown, location.abovebar, color = color.red, size = size.small)
plotshape(strategy.position_size > 0 and mode == "MR" and mrExit, "撈底出場", shape.triangledown, location.abovebar, color = color.orange, size = size.small)

// 指標數值喺 Data Window 睇
plot(macdLine, "淨 MACD(5,35)", color = color.teal, display = display.data_window)
plot(rsiVal, "RSI(2)", color = color.purple, display = display.data_window)
