//@version=6
strategy("順勢交易_優化版",
     overlay = true,
     pyramiding = 0,
     initial_capital = 100000,
     default_qty_type = strategy.percent_of_equity,
     default_qty_value = 100) // 實盤建議調低，例如 20-30%

// --- 輸入參數 ---
breakoutLen = input.int(20, "新高日數 (突破)", minval = 1)
exitLen     = input.int(10, "新低日數 (出場)", minval = 1)
fastLen     = input.int(5,  "MACD 快線", minval = 1)
slowLen     = input.int(35, "MACD 慢線", minval = 1)
signalLen   = input.int(5,  "MACD 訊號線", minval = 1)
maLen       = input.int(200,"MA 長期趨勢線", minval = 1)

// --- 指標計算 ---
[macdLine, signalLine, histLine] = ta.macd(close, fastLen, slowLen, signalLen)

// 修正：取前一根 K 線算出的區間極值，避免包含當前 K 線
highestHigh = ta.highest(high, breakoutLen)[1]
lowestLow   = ta.lowest(low, exitLen)[1]
ma          = ta.sma(close, maLen)

// --- 訊號判斷 ---
isHighestHigh = high > highestHigh // 改為大於「過去」的最高點
isLowestLow   = low < lowestLow   // 改為小於「過去」的最低點

buySignal  = isHighestHigh and macdLine > 0 and close > ma
sellSignal = isLowestLow

// --- 交易執行 ---
if buySignal and strategy.position_size <= 0
    strategy.entry("BUY", strategy.long)

if sellSignal and strategy.position_size > 0
    strategy.close("BUY")

// --- 繪圖可視化 ---
plot(highestHigh, "20日新高線", color = color.new(color.green, 0), linewidth = 2)
plot(lowestLow, "10日新低線", color = color.new(color.red, 0), linewidth = 2)
plot(ma, "200MA", color = color.new(color.blue, 0), linewidth = 2)

plotshape(isHighestHigh, "H20", shape.labeldown, location.abovebar, color = color.green, text = "H20", textcolor = color.white, size = size.tiny)
plotshape(isLowestLow, "L10", shape.labelup, location.belowbar, color = color.red, text = "L10", textcolor = color.white, size = size.tiny)

// MACD 數值僅顯示於 Data Window
plot(macdLine, "MACD line", color = color.teal, display = display.data_window)
plot(signalLine, "MACD signal", color = color.orange, display = display.data_window)
plot(histLine, "MACD hist", color = color.gray, display = display.data_window)